{
  "name": "@duskmoon-dev/css-art",
  "version": "1.12.0",
  "description": "Pure CSS art components - decorative illustrations built entirely with CSS",
  "type": "module",
  "main": "./dist/index.css",
  "exports": {
    ".": {
      "default": "./dist/index.css",
      "style": "./dist/index.css"
    },
    "./art": {
      "style": "./dist/art/index.css"
    },
    "./dist/art/*.css": "./dist/art/*.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run build --watch",
    "build": "bun run clean && bun run build:css",
    "build:css": "bun run scripts/build-css.ts",
    "clean": "rm -rf dist",
    "test": "bun test tests/unit",
    "test:unit": "bun test tests/unit"
  },
  "keywords": [
    "css-art",
    "pure-css",
    "illustrations",
    "decorative",
    "css-only",
    "css-drawings"
  ],
  "author": "DuskMoon Development",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duskmoon-dev/duskmoonui.git",
    "directory": "packages/css-art"
  },
  "homepage": "https://github.com/duskmoon-dev/duskmoonui#readme",
  "bugs": {
    "url": "https://github.com/duskmoon-dev/duskmoonui/issues"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lightningcss": "^1.22.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
