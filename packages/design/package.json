{
  "name": "@duskmoon-dev/design",
  "version": "1.0.0",
  "description": "DuskMoon UI design tokens — framework-agnostic YAML source of truth",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "bun run scripts/codegen.ts generate --target all",
    "generate:ts": "bun run scripts/codegen.ts generate --target typescript",
    "generate:dart": "bun run scripts/codegen.ts generate --target dart",
    "generate:json": "bun run scripts/codegen.ts generate --target json",
    "generate:css": "bun run scripts/codegen.ts generate --target css",
    "validate": "bun run scripts/codegen.ts validate",
    "diff": "bun run scripts/codegen.ts diff",
    "docs": "bun run scripts/codegen.ts docs",
    "test": "bun test",
    "check": "bun run validate && bun test"
  },
  "devDependencies": {
    "yaml": "^2.4.0",
    "@types/bun": "latest"
  }
}
